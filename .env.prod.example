# ──────────────────────────────────────────────────────────────────────────
# Seovivu — production environment template
#
# Copy to `.env.prod`, fill in real values, and load it before starting the
# release (e.g. systemd `EnvironmentFile=`, or `set -a; . ./.env.prod; set +a`).
# NEVER commit the filled-in .env.prod — keep secrets out of version control.
# ──────────────────────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────────────────────

# Public apex hostname (no scheme, no trailing slash).
# The "Gửi Index" app is served from  index.<PHX_HOST>  automatically — both
# the Phoenix host-based router and the Caddyfile derive the subdomain from
# this single value.
PHX_HOST=seovivu.com

# Cookie/token signing & encryption key. Generate a fresh one with:
#   mix phx.gen.secret
SECRET_KEY_BASE=

# PostgreSQL connection string:  ecto://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=ecto://seovivu:CHANGE_ME@127.0.0.1:5432/seovivu_prod

# Start the web server inside the release. Without this the app boots but
# serves no HTTP. (mix phx.gen.release's bin/server sets this for you.)
PHX_SERVER=true

# ── Optional (defaults shown) ──────────────────────────────────────────────

# Internal HTTP port Phoenix binds to on localhost; Caddy reverse-proxies here.
PORT=4000

# DB connection pool size. Raise it if many users run batches concurrently.
POOL_SIZE=10

# Set to "true" only if the DATABASE_URL host is reachable solely over IPv6.
ECTO_IPV6=false

# libcluster DNS discovery for multi-node clustering. Leave empty on a single
# VPS (the per-user concurrency cap is per-node — see the deploy notes).
DNS_CLUSTER_QUERY=

# Email shown to Let's Encrypt for cert-expiry notices (used by the Caddyfile).
# Optional but recommended; leave empty to issue certs without a contact.
ACME_EMAIL=

# ── NOT environment variables ──────────────────────────────────────────────
# The following are stored in the database (admin → Cài đặt), NOT here:
#   • Telegram bot token + bot username
#   • Telegram webhook secret (the /telegram/webhook/:secret path segment)
#   • ScrapingDog API key
#   • Proxy list
# In production the Telegram webhook delivers updates; the dev long-poller is
# off, so remember to call setWebhook from the admin Telegram page after deploy.
